# POS Connect — configuration serveur
# Copiez ce fichier en pos_server.ini et adaptez les valeurs.
# Le wizard d'installation le génère automatiquement.

[database]
# "mysql" ou "sqlite"
type     = mysql
host     = localhost
port     = 3306
name     = pos_db
user     = root
password = @#1900

# Chemin du fichier SQLite (ignoré si type = mysql)
path     = ./pos_data.db

[server]
host                  = 0.0.0.0
port                  = 8002
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
secret_key            = changez_moi_avec_une_cle_secrete_aleatoire_32_bytes
token_expire_minutes  = 480
# Compte super-admin pour le panel /admin
# Générer le hash : python -c "from api.services.auth import Auth; print(Auth.get_password_hash('VotreMotDePasse'))"
admin_email           =
admin_password_hash   =

# Synchronisation local ↔ cloud
# Configurer via POST /api/sync/configure (remplit automatiquement ces champs)
cloud_sync_url        =
cloud_sync_token      =
cloud_sync_enabled    = false

# Identité serveur — clé privée Ed25519 (base64, 32 octets)
# UNIQUEMENT sur le serveur cloud SaaS — ne pas mettre sur les serveurs clients
# Générer : python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; from cryptography.hazmat.primitives.serialization import Encoding,PrivateFormat,NoEncryption; import base64; k=Ed25519PrivateKey.generate(); print(base64.b64encode(k.private_bytes(Encoding.Raw,PrivateFormat.Raw,NoEncryption())).decode())"
identity_private_key  =

# URL du serveur de billing (posconnect.ht).
# Pour les tenants self-hosted, l'app Flutter utilise cette URL pour vérifier
# la licence/plan même si les données business vont vers leur propre serveur.
# Rempli automatiquement par le wizard lors de la connexion tenant.
billing_url           =

# Origines CORS autorisées (séparées par virgule).
# "*" = tout autoriser (développement local).
# Production : https://post.institutionlemignon.com
cors_origins          = *

# Répertoire du build Flutter web (servi par FastAPI comme SPA).
# Copier le contenu de frontend/build/web/ dans ce dossier.
# Laisser vide pour désactiver le serving web intégré.
web_dir               = web
